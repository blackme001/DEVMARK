-- FIX: RLS Policy Violations for Purchases and Messages

-- 1. Enable RLS (already done, but just in case)
ALTER TABLE public."Purchase" ENABLE ROW LEVEL SECURITY;
ALTER TABLE public."Message" ENABLE ROW LEVEL SECURITY;

-- 2. Allow SYSTEM / Webhooks to insert Purchases
-- Since we are currently using an unauthenticated webhook client (non-admin), 
-- we need to temporarily allow inserts if we don't use the Service Role key.
-- BEST PRACTICE: Only allows inserts from Authenticated users or the Service Role.
CREATE POLICY "Enable insert for authenticated users only" 
ON public."Purchase" FOR INSERT 
WITH CHECK (auth.role() = 'authenticated');

-- 3. Allow viewing of all purchases for testing (Optional/Unsafe in prod)
-- CREATE POLICY "Allow viewing all purchases" ON public."Purchase" FOR SELECT USING (true);

-- 4. Ensure Message insertion policy matches auth.uid()
DROP POLICY IF EXISTS "Users can send messages" ON public."Message";
CREATE POLICY "Users can send messages" 
ON public."Message" FOR INSERT 
WITH CHECK (auth.uid() = "senderId");

-- 5. Ensure Project creation policy
DROP POLICY IF EXISTS "Creators can insert own projects" ON public."Project";
CREATE POLICY "Creators can insert own projects" 
ON public."Project" FOR INSERT 
WITH CHECK (auth.uid() = "creatorId");
